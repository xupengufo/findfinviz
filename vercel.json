{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "finvizfinance/**"
      }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(styles.css|app.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/styles.css", "dest": "public/styles.css" },
    { "src": "/app.js", "dest": "public/app.js" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
